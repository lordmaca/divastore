  ensure_root
  info "Aplicando sugestões de alta confiança"
  node --env-file=.env.local ./node_modules/.bin/tsx scripts/categorize-apply-cli.ts
}

cmd_categorize_issues() {
  ensure_root
  local n="${1:-20}"
  psql_local -c "
    SELECT to_char(i.\"createdAt\", 'MM-DD HH24:MI') AS at,
           substring(p.name, 1, 50) AS product,
           substring(cur.name, 1, 14) AS atual,
           substring(sug.name, 1, 14) AS sugestao,
           i.confidence AS conf,
           i.status
    FROM \"CategoryAuditIssue\" i
    JOIN \"Product\" p ON p.id = i.\"productId\"
    LEFT JOIN \"Category\" cur ON cur.id = i.\"currentCategoryId\"
    LEFT JOIN \"Category\" sug ON sug.id = i.\"suggestedCategoryId\"
    WHERE i.status = 'OPEN'
    ORDER BY i.\"createdAt\" DESC LIMIT $n;"
}

cmd_order() {
  ensure_root
  local num="${1:-}"
  [[ -n "$num" ]] || die "Usage: bdd order <number>"
  echo "--- Pedido #$num ---"
  psql_local -c "
    SELECT o.id, o.number, o.status, o.\"totalCents\"/100.0 AS total_brl,
           c.email AS customer, o.\"lastPaymentMethod\" AS method,
           o.\"lastPaymentStatus\" AS pstatus, o.\"trackingCode\" AS tracking,
           o.\"tinyOrderId\" AS tiny
    FROM \"Order\" o LEFT JOIN \"Customer\" c ON c.id = o.\"customerId\"
    WHERE o.number = $num;"
  echo "--- Pagamentos ---"
  psql_local -c "
    SELECT p.method, p.status, p.\"amountCents\"/100.0 AS bruto,
           p.\"feeCents\"/100.0 AS taxa, p.\"netReceivedCents\"/100.0 AS liquido,
           p.\"refundedCents\"/100.0 AS reembolso, p.installments AS parc,
           p.\"cardLastFour\" AS card4, p.\"paymentTypeId\" AS type
    FROM \"Payment\" p JOIN \"Order\" o ON o.id = p.\"orderId\"
    WHERE o.number = $num ORDER BY p.\"createdAt\" DESC;"
  echo "--- Timeline (últimos 20) ---"
  psql_local -c "
    SELECT to_char(e.\"createdAt\", 'YYYY-MM-DD HH24:MI:SS') AS at,
           e.type, e.actor, substring(COALESCE(e.message, ''), 1, 70) AS message
    FROM \"OrderEvent\" e JOIN \"Order\" o ON o.id = e.\"orderId\"
    WHERE o.number = $num
    ORDER BY e.\"createdAt\" DESC LIMIT 20;"
}

cmd_events() {
  ensure_root
  local oid="${1:-}"
  [[ -n "$oid" ]] || die "Usage: bdd events <orderId> [n]"
  local n="${2:-20}"
  psql_local -c "
    SELECT to_char(\"createdAt\", 'MM-DD HH24:MI:SS') AS at,
           type, actor, substring(COALESCE(message, ''), 1, 70) AS message
    FROM \"OrderEvent\"
    WHERE \"orderId\" = '$oid'
    ORDER BY \"createdAt\" DESC LIMIT $n;"
}

