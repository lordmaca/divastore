cmd_test_email() {
  ensure_root
  local to="${1:-}"
  [[ -n "$to" ]] || die "Usage: bdd test-email <recipient@example.com>"
  info "Sending test email to $to"
  node --env-file=.env.local -e "
    (async () => {
      const { sendEmail, emailConfigured } = await import('./lib/notifications/channels/email.ts');
      if (!(await emailConfigured())) { console.error('SMTP not configured (set via /admin/configuracoes)'); process.exit(1); }
      await sendEmail({
        to: '$to',
        subject: 'Teste — Brilho de Diva',
        text: 'Este é um e-mail de teste do painel de administração.',
        html: '<p>Este é um e-mail de teste do painel de administração.</p>',
      });
      console.log('ok');
    })().catch((e) => { console.error(e); process.exit(1); });
  " 2>&1 || die "send failed — check EMAIL_SMTP_* in .env.local"
  ok "sent — verify inbox"
}

cmd_migrate_env_to_db() {
  ensure_root
  grep -qE '^SETTINGS_ENCRYPTION_KEY=' .env.local 2>/dev/null \
    || die "SETTINGS_ENCRYPTION_KEY não encontrado em .env.local — rode a bootstrap primeiro"
  info "Copiando env vars legadas para SettingsKv (criptografado)"
  node --env-file=.env.local ./node_modules/.bin/tsx scripts/migrate-env-to-db.ts \
    || die "falha na migração — veja o erro acima"
  ok "migração concluída — abra /admin/configuracoes e confirme o estado"
}

cmd_backup() {
  ensure_root
  local do_code=1 do_db=1 msg=""
  local BACKUP_DIR="/home/ubuntu/backups"
  local KEEP=14 # last 14 local snapshots

  for arg in "$@"; do
    case "$arg" in
      --code-only) do_db=0 ;;
      --db-only)   do_code=0 ;;
      *)           msg="$arg" ;;
    esac
  done

  mkdir -p "$BACKUP_DIR"
  local ts; ts=$(date +%Y%m%d-%H%M%S)

  # --- Local code tarball (excludes node_modules, .next, logs, backups,
  # lib/generated — everything in .gitignore + a few extras).
  if [[ $do_code -eq 1 ]]; then
    local tar_path="$BACKUP_DIR/brilhodediva-code-$ts.tar.gz"
    info "→ Snapshot do código: $tar_path"
    tar -czf "$tar_path" \
      --exclude='./node_modules' \
      --exclude='./.next' \
      --exclude='./logs' \
      --exclude='./backups' \
      --exclude='./lib/generated' \
      --exclude='./.git' \
      --exclude='./*.tsbuildinfo' \
      -C "$BDD_ROOT" . \
      && ok "code tarball $(du -h "$tar_path" | cut -f1)" \
      || { warn "tarball do código falhou"; do_code=0; }
  fi

  # --- Postgres dump
  if [[ $do_db -eq 1 ]]; then
    local dump_path="$BACKUP_DIR/brilhodediva-db-$ts.sql.gz"
    info "→ Dump Postgres: $dump_path"
    PGPASSWORD=$(db_password) pg_dump -h 127.0.0.1 -U brilhodediva \
      --no-owner --no-privileges brilhodediva \
      | gzip > "$dump_path" \
      && ok "db dump $(du -h "$dump_path" | cut -f1)" \
      || { warn "pg_dump falhou"; rm -f "$dump_path"; }
  fi

  # --- Prune old local backups (keep last $KEEP of each kind)
  info "→ Prune local: mantendo últimos $KEEP snapshots"
  ls -1t "$BACKUP_DIR"/brilhodediva-code-*.tar.gz 2>/dev/null | tail -n +$((KEEP + 1)) | xargs -r rm -f
  ls -1t "$BACKUP_DIR"/brilhodediva-db-*.sql.gz     2>/dev/null | tail -n +$((KEEP + 1)) | xargs -r rm -f

  # --- GitHub push (only on a full or --code-only run; --db-only skips)
  if [[ $do_code -eq 1 ]]; then
    local token repo commit_msg
    token=$(grep "^GITHUB_TOKEN=" .env.local 2>/dev/null | cut -d= -f2-)
    repo=$(grep "^GITHUB_REPO=" .env.local 2>/dev/null | cut -d= -f2-)
    if [[ -z "$token" || -z "$repo" ]]; then
      warn "GITHUB_TOKEN ou GITHUB_REPO ausente em .env.local — pulo o push pro GitHub"
    else
      commit_msg="${msg:-backup: $ts}"
      info "→ Commit + push (GitHub $repo)"
      git add -A
      if git diff --cached --quiet; then
        info "sem mudanças para commitar — push só do HEAD atual"
      else
        git commit -m "$commit_msg" --quiet
      fi
      git push "https://x-access-token:${token}@github.com/${repo}.git" HEAD:main 2>&1 \
        | grep -vE "^(Enumerating|Counting|Delta|Compressing|Writing|remote: |To https)" \
        || true
      ok "push concluído"
    fi
  fi

  ok "backup $ts concluído"
}

cmd_smoke() {
  ensure_root
  info "Curling public routes"
  local paths=(/ /loja /carrinho /checkout /login /cadastro /recuperar-senha /api/health)
  for p in "${paths[@]}"; do
    local code
    code=$(curl -sS --resolve "loja.brilhodediva.com.br:443:$STOREFRONT_IP" \
      -o /dev/null -w "%{http_code}" --max-time 8 "$STOREFRONT_URL$p" || echo "000")
    printf "  %-28s %s\n" "$p" "$code"
  done
}

cmd_env() {
  ensure_root
  info "env vars seen by bdd (value masked)"
  for v in \
    DATABASE_URL AUTH_URL AUTH_TRUST_HOST AUTH_SECRET SETTINGS_ENCRYPTION_KEY \
    MP_ACCESS_TOKEN MP_WEBHOOK_SECRET MP_PUBLIC_KEY \
    TINY_API_TOKEN TINY_API_BASE_URL TINY_WEBHOOK_SECRET \
    DIVAHUB_API_URL DIVAHUB_API_KEY \
    EMAIL_SMTP_HOST EMAIL_SMTP_PORT EMAIL_SMTP_USER EMAIL_SMTP_PASS EMAIL_FROM EMAIL_REPLY_TO \
    WHATSAPP_ACCESS_TOKEN WHATSAPP_PHONE_NUMBER_ID \
    MELHORENVIO_TOKEN MELHORENVIO_ENV MELHORENVIO_WEBHOOK_SECRET \
    STOREFRONT_DEMO_MODE
  do
    local line
    line=$(grep -E "^$v=" .env.local 2>/dev/null || true)
    if [[ -n "$line" ]]; then
      local val="${line#$v=}"
      val="${val//\"/}"
      if [[ -n "$val" ]]; then
        printf "  %-28s ${GREEN}set${NC} (len=%d)\n" "$v" "${#val}"
      else
        printf "  %-28s ${YELLOW}empty${NC}\n" "$v"
      fi
    else
      printf "  %-28s ${YELLOW}unset${NC}\n" "$v"
    fi
  done
}

# ---- Entrypoint -------------------------------------------------------------

cmd="${1:-help}"
shift || true

case "$cmd" in
  help|--help|-h)         cmd_help "$@" ;;
  status)                  cmd_status "$@" ;;
  bootstrap)               cmd_bootstrap "$@" ;;
  start)                   cmd_start "$@" ;;
  stop)                    cmd_stop "$@" ;;
  restart)                 cmd_restart "$@" ;;
  reload)                  cmd_reload "$@" ;;
  logs)                    cmd_logs "$@" ;;
  build)                   cmd_build "$@" ;;
  typecheck)               cmd_typecheck "$@" ;;
  deploy)                  cmd_deploy "$@" ;;
  migrate)                 cmd_migrate "$@" ;;
  migrate-dry)             cmd_migrate_dry "$@" ;;
  studio)                  cmd_studio "$@" ;;
  psql)                    cmd_psql "$@" ;;
  seed)                    cmd_seed "$@" ;;
  health)                  cmd_health "$@" ;;
  notifications)           cmd_notifications "$@" ;;
  failed-notifications)    cmd_failed_notifications "$@" ;;
  funnel)                  cmd_funnel "$@" ;;
  retry)                   cmd_retry "$@" ;;
  abandoned)               cmd_abandoned "$@" ;;
  sync-stock)              cmd_sync_stock "$@" ;;
  stock-events)            cmd_stock_events "$@" ;;
  categorize-scan)         cmd_categorize_scan "$@" ;;
  categorize-apply)        cmd_categorize_apply "$@" ;;
  categorize-issues)       cmd_categorize_issues "$@" ;;
  order)                   cmd_order "$@" ;;
  events)                  cmd_events "$@" ;;
  backfill-events)         cmd_backfill_events "$@" ;;
  invoice)                 cmd_invoice "$@" ;;
  invoice-status)          cmd_invoice_status "$@" ;;
  invoice-poll)            cmd_invoice_poll "$@" ;;
  refund)                  cmd_refund "$@" ;;
  label)                   cmd_label "$@" ;;
  shipments)               cmd_shipments "$@" ;;
  delete-order)            cmd_delete_order "$@" ;;
  test-email)              cmd_test_email "$@" ;;
  migrate-env-to-db)       cmd_migrate_env_to_db "$@" ;;
  backup)                  cmd_backup "$@" ;;
  smoke)                   cmd_smoke "$@" ;;
  env)                     cmd_env "$@" ;;
  *)
    die "Unknown command: '$cmd'. Run './scripts/bdd help' for the list."
    ;;
esac
