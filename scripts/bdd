cmd_stock_events() {
  ensure_root
  local n="${1:-30}"
  psql_local -c "
    SELECT
      to_char(\"createdAt\", 'MM-DD HH24:MI') AS at,
      sku,
      \"oldStock\" AS old,
      \"newStock\" AS new,
      source
    FROM \"StockSyncEvent\"
    ORDER BY \"createdAt\" DESC
    LIMIT $n;"
}

cmd_categorize_scan() {
  ensure_root
  local extra=()
  [[ "${1:-}" == "--dry" || "${1:-}" == "--dry-run" ]] && extra+=("--dry")
  info "Rodando category-scan"
  node --env-file=.env.local ./node_modules/.bin/tsx scripts/scan-categories.ts "${extra[@]}"
