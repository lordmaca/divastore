cmd_shipments() {
  ensure_root
  local n="${1:-20}"
  psql_local -c "
    SELECT to_char(s.\"createdAt\", 'MM-DD HH24:MI') AS at,
           o.number AS order_num,
           s.carrier, s.\"serviceId\" AS service,
           s.status,
           COALESCE(s.\"trackingCode\", '-') AS tracking,
           s.\"priceCents\"/100.0 AS price_brl
    FROM \"Shipment\" s JOIN \"Order\" o ON o.id = s.\"orderId\"
    ORDER BY s.\"createdAt\" DESC LIMIT $n;"
}

