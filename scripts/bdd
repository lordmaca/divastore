cmd_invoice_status() {
  ensure_root
  local num="${1:-}"
  [[ -n "$num" ]] || die "Usage: bdd invoice-status <orderNumber>"
  psql_local -c "
    SELECT i.status, i.number, i.serie, i.\"providerInvoiceId\" AS tiny_nf,
           i.\"issuedAt\", i.attempts,
           substring(COALESCE(i.\"lastError\", ''), 1, 80) AS last_error
    FROM \"Invoice\" i JOIN \"Order\" o ON o.id = i.\"orderId\"
    WHERE o.number = $num
    ORDER BY i.\"createdAt\" DESC LIMIT 5;"
}

